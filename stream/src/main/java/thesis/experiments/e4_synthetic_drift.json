{
  "experiment_group": "E4",
  "output_dir": "results/E4",

  "warmup": 1500,
  "window_size": 1000,
  "log_every": 1000,
  "ram_sample_every": 200,
  "importance_update_every": 500,
  "tolerance_window": 500,
  "max_instances": 50000,
  "detector_delta": 0.002,
  "f1_threshold": 0.5,
  "kappa_threshold": 0.5,

  "drift_before_window": 500,
  "drift_after_window": 500,

  "seeds": [1],

  "magnitudes": ["LOW", "MEDIUM", "HIGH"],

  "methods": [
    "HT+S1",
    "ARF+S1", "ARF+S2", "ARF+S3",
    "SRP+S1", "SRP+S2", "SRP+S3",
    "DA-SRP-A", "DA-SRP-AB", "DA-SRP-ABC"
  ],

  "generators": [
    { "name": "SEA",                "n": 50000, "noise_features": 0 },
    { "name": "Hyperplane",         "n": 50000, "noise_features": 0 },
    { "name": "RandomRBF",          "n": 50000, "noise_features": 0 },
    { "name": "STAGGER",            "n": 50000, "noise_features": 0 },
    { "name": "CustomFeatureDrift", "n": 50000, "noise_features": 5, "drift_features": 5 }
  ]
}
